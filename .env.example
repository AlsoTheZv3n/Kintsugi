# Vorlage fuer .env. Kopieren und anpassen; .env selbst ist in .gitignore.
# Ein Test haelt diese Datei und die Felder von kintsugi/config.py deckungs-
# gleich: fehlt hier ein Schluessel oder steht einer zu viel drin, wird er rot.

# --- Datenbank ---------------------------------------------------------------
KINTSUGI_PG_HOST=localhost
# Auf einer XAMPP-Maschine ist 5432 haeufig belegt. Dieser Wert bewegt die URL,
# die die Anwendung tatsaechlich waehlt.
KINTSUGI_PG_PORT=5432
KINTSUGI_PG_USER=kintsugi
KINTSUGI_PG_PASSWORD=kintsugi
KINTSUGI_PG_DB=kintsugi
# Setzt alle Einzelteile ausser Kraft. Leer lassen, ausser die URL kommt
# vollstaendig von aussen (z. B. aus einem CI-Dienst). Wird als Geheimnis
# behandelt, weil eine solche URL das Passwort im Klartext mitfuehrt.
KINTSUGI_DATABASE_URL_OVERRIDE=

# --- Ablage ------------------------------------------------------------------
KINTSUGI_SNAPSHOT_ROOT=./data/bronze
KINTSUGI_PACKS_DIR=packs

# --- Netz und Identitaet -----------------------------------------------------
KINTSUGI_USER_AGENT_PRODUCT=kintsugi/0.1
# Pflicht, sobald tatsaechlich abgerufen wird. Die README verpflichtet das
# Projekt auf einen identifizierbaren User-Agent mit Kontaktadresse; ohne
# diesen Wert verweigert der Fetcher den Dienst.
KINTSUGI_CONTACT=
KINTSUGI_HTTP_TIMEOUT_S=20.0

# --- Sonstiges ---------------------------------------------------------------
KINTSUGI_LOG_LEVEL=INFO
# Erst ab Phase 4 relevant (LLM-Vorschlagsstufe).
KINTSUGI_ANTHROPIC_API_KEY=
